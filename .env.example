SSU_ID=your_student_id
SSU_PASSWORD=your_password

# Discord 채널 웹훅 URL (채널 설정 → 연동 → 웹후크)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# 슬래시 명령 봇 토큰 (Developer Portal → Bot → Token)
DISCORD_BOT_TOKEN=your_bot_token_here

# 봇이 속한 서버 ID (우클릭 → 서버 ID 복사, 개발자 모드 필요)
# main.py가 /마감알림설정 값을 읽을 때 사용
DISCORD_GUILD_ID=123456789012345678

# 과제 알림 간격(초). Discord rate limit 완화용 (기본 0.5)
DISCORD_SEND_DELAY_SEC=0.5

# 마감 임박 알림 기본값(시간). 봇 명령으로 바꾸기 전 초기값 (기본 24)
DUE_SOON_HOURS=24

# false면 main 실행 시 전체 과제 알림은 건너뛰고, 마감 임박 알림만 전송
SSU_SEND_ALL_ASSIGNMENTS=true

# GitHub Actions / 서버에서는 headless 권장
SSU_HEADLESS=true

# 진행 중(마감 전) 과제만 수집 (기본 true)
SSU_ONLY_ACTIVE_ASSIGNMENTS=true
